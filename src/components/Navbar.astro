---
const links = [
  { href: '/blog/posts/', label: 'Posts' },
  { href: '/blog/topics/', label: 'Topics' },
  { href: '/blog/about/', label: 'About' }
];
---

<div class="flex flex-row gap-8">
  {
    links.map((link) => (
      <a
        href={link.href}
        class="hover:text-sage no-underline text-[11px] tracking-[0.15em] uppercase text-muted transition-colors"
      >
        {link.label}
      </a>
    ))
  }
</div>
