---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Globe, Linkedin, Github, Mail } from 'lucide-astro';

const title = 'About me';
const description = 'Some info about myself';

const contactOptions = [
  {
    link: 'https://korotkaya.com/',
    icon: Globe,
    alt: 'Website'
  },
  {
    link: 'https://www.linkedin.com/in/irinakorotkaya/',
    icon: Linkedin,
    alt: 'LinkedIn'
  },
  {
    link: 'https://github.com/ikorotkaya',
    icon: Github,
    alt: 'GitHub'
  },
  {
    link: 'mailto:irina@korotkaya.com',
    icon: Mail,
    alt: 'Gmail'
  }
];
---

<BaseLayout title={title} description={description}>
  <div class="mb-12 flex-grow">
    <p
      class="not-prose text-[11px] tracking-[0.15em] uppercase text-muted mb-4 mt-0"
    >
      {title}
    </p>
    <p class="mt-0">
      I'm Irina. Sensitive to beauty and detail, occasionally
      overwhelmed by both. Spent years designing buildings, now I
      write code. Based in Berlin.
    </p>
    <div class="not-prose flex gap-3 items-center mt-4">
      {
        contactOptions.map((option) => (
          <a
            href={option.link}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={option.alt}
            class="text-muted hover:text-sage transition-colors"
          >
            <option.icon size={18} aria-hidden="true" />
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
