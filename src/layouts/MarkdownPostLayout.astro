---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import { format } from 'date-fns';

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return format(date, 'dd MMMM yyyy');
};

const { frontmatter, description, title } = Astro.props;
---

<BaseLayout description={description} title={title}>
  <article class="flex flex-col max-w-full flex-grow">
    <header class="mb-8">
      <p
        class="text-[11px] tracking-[0.12em] uppercase text-muted mt-0 mb-5"
      >
        {formatDate(frontmatter.pubDate)}
      </p>
      <h1 class="mt-0">{frontmatter.title}</h1>
    </header>
    <main>
      <slot />
    </main>
    <div class="not-prose flex flex-wrap gap-2 mt-12 mb-12">
      {
        frontmatter.tags.map((tag: string) => (
          <Tag key={tag} tag={tag} />
        ))
      }
    </div>
  </article>
</BaseLayout>
